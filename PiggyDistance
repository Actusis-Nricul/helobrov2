local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")

local Player = Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()

local PiggyFolder = workspace:FindFirstChild("PiggyNPC")
if not PiggyFolder then return end

local Piggy

for _, v in ipairs(PiggyFolder:GetChildren()) do
	if v:IsA("Model") and v:FindFirstChildOfClass("Humanoid") then
		Piggy = v
		break
	end
end

if not Piggy then return end

local PiggyRoot = Piggy:FindFirstChild("HumanoidRootPart") or Piggy.PrimaryPart
local MyRoot = Character:WaitForChild("HumanoidRootPart")

if PiggyRoot and MyRoot then
	local Distance = math.floor((MyRoot.Position - PiggyRoot.Position).Magnitude)

	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = "Piggy Distance",
			Text = Distance .. " studs away",
			Duration = 4
		})
	end)
end
