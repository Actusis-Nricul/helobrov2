local function wipeMap(map)

	for _, obj in ipairs(map:GetDescendants()) do

		pcall(function()
			obj:Destroy()
		end)

	end
end

while task.wait() do

	for _, obj in ipairs(workspace:GetChildren()) do

		if maps[obj.Name] then
			wipeMap(obj)
		end

	end
end
