local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

getgenv().FacePiggyEnabled = not getgenv().FacePiggyEnabled

if getgenv().FacePiggyConnection then
	getgenv().FacePiggyConnection:Disconnect()
	getgenv().FacePiggyConnection = nil
end

if not getgenv().FacePiggyEnabled then
	return
end

local Player = Players.LocalPlayer

local PiggyFolder = workspace:FindFirstChild("PiggyNPC")
if not PiggyFolder then return end

local Piggy

for _, v in ipairs(PiggyFolder:GetChildren()) do
	if v:IsA("Model") and v:FindFirstChildOfClass("Humanoid") then
		Piggy = v
		break
	end
end

if not Piggy then return end

local PiggyRoot = Piggy:FindFirstChild("HumanoidRootPart") or Piggy.PrimaryPart
if not PiggyRoot then return end

getgenv().FacePiggyConnection = RunService.RenderStepped:Connect(function()
	local Character = Player.Character
	if not Character then return end

	local Root = Character:FindFirstChild("HumanoidRootPart")
	if not Root then return end

	Root.CFrame = CFrame.lookAt(
		Root.Position,
		Vector3.new(
			PiggyRoot.Position.X,
			Root.Position.Y,
			PiggyRoot.Position.Z
		)
	)
end)
