local discordBtn = makeButton("Copy Discord Server", 350)

discordBtn.MouseButton1Click:Connect(function()

	-- copies invite to clipboard
	if setclipboard then
		setclipboard("https://discord.gg/ANwZKq8D6a")
	end

	-- some executors support this
	if syn and syn.request then
		syn.request({
			Url = "https://discord.gg/ANwZKq8D6a",
			Method = "GET"
		})
	end
end)
