local ClickDetectors = {}

for _, obj in ipairs(workspace:GetChildren()) do
	-- Look for ItemFolder or a folder with only numbers in its name
	if obj.Name == "ItemFolder" or obj.Name:match("^%d+$") then
		for _, descendant in ipairs(obj:GetDescendants()) do
			if descendant:IsA("ClickDetector") then
				table.insert(ClickDetectors, descendant)
			end
		end
	end
end

if #ClickDetectors == 0 then
	warn("No ClickDetectors found in ItemFolder/numeric folder.")
	return
end

-- Pick ONE random ClickDetector
local RandomDetector = ClickDetectors[math.random(#ClickDetectors)]

-- Fire it a random number of times
local TimesToFire = math.random(10, 20)

for i = 1, TimesToFire do
	fireclickdetector(RandomDetector)
	task.wait(0.1)
end

print(("Fired %s %d times"):format(
	RandomDetector:GetFullName(),
	TimesToFire
))
