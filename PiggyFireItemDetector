local ClickDetectors = {}

for _, v in ipairs(workspace:GetDescendants()) do
	if v:IsA("ClickDetector") then
		table.insert(ClickDetectors, v)
	end
end

if #ClickDetectors == 0 then
	warn("No ClickDetectors found.")
	return
end

local RandomDetector = ClickDetectors[math.random(1, #ClickDetectors)]

local TimesToFire = math.random(2, 3)

for i = 1, TimesToFire do
	fireclickdetector(RandomDetector)
	task.wait(0.1) -- small delay between clicks
end

print(("Fired %s %d times"):format(RandomDetector:GetFullName(), TimesToFire))
