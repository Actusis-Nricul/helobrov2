local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

getgenv().PiggyTracerEnabled = not getgenv().PiggyTracerEnabled

if getgenv().PiggyTracerConnection then
	getgenv().PiggyTracerConnection:Disconnect()
	getgenv().PiggyTracerConnection = nil
end

if getgenv().PiggyTracerLine then
	getgenv().PiggyTracerLine:Remove()
	getgenv().PiggyTracerLine = nil
end

if not getgenv().PiggyTracerEnabled then
	return
end

local Camera = workspace.CurrentCamera
local Player = Players.LocalPlayer

local PiggyFolder = workspace:FindFirstChild("PiggyNPC")
if not PiggyFolder then return end

local Piggy

for _, v in ipairs(PiggyFolder:GetChildren()) do
	if v:IsA("Model") and v:FindFirstChildOfClass("Humanoid") then
		Piggy = v
		break
	end
end

if not Piggy then return end

local PiggyRoot = Piggy:FindFirstChild("HumanoidRootPart") or Piggy.PrimaryPart
if not PiggyRoot then return end

local Line = Drawing.new("Line")
Line.Thickness = 2
Line.Transparency = 1

getgenv().PiggyTracerLine = Line

getgenv().PiggyTracerConnection = RunService.RenderStepped:Connect(function()
	local Character = Player.Character
	if not Character then return end

	local Root = Character:FindFirstChild("HumanoidRootPart")
	if not Root then return end

	local A, AV = Camera:WorldToViewportPoint(Root.Position)
	local B, BV = Camera:WorldToViewportPoint(PiggyRoot.Position)

	if AV and BV then
		Line.Visible = true
		Line.From = Vector2.new(A.X, A.Y)
		Line.To = Vector2.new(B.X, B.Y)
	else
		Line.Visible = false
	end
end)
